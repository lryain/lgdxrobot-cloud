@using LGDXRobotCloud.Data.Models.Redis


<div class="col-sm-6 col-lg-3">
  <div class="card h-100">
    <div class="card-body d-flex flex-column">
      <div class="subheader">CPU Usage</div>
      <div class="h1 flex-grow-1">@(Math.Round((RobotData?.SystemMonitoringInfo.CpuUsage ?? 0), 1))%</div>
      <div id="chart-cpu-usage" class="position-relative rounded-bottom chart-sm"></div>
    </div>
  </div>
</div>
<div class="col-sm-6 col-lg-3">
  <div class="card h-100">
    <div class="card-body d-flex flex-column">
      <div class="subheader">Memory</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.MemoryTotal ?? 0)</div>
      <div class="subheader">Memory Used</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.MemoryUsed ?? 0)</div>
      <div id="chart-memory-usage" class="position-relative rounded-bottom chart-sm"></div>
    </div>
  </div>
</div>
<div class="col-sm-6 col-lg-3">
  <div class="card h-100">
    <div class="card-body d-flex flex-column">
      <div class="subheader">Swap</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.SwapTotal ?? 0)</div>
      <div class="subheader">Swap Used</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.SwapUsed ?? 0)</div>
      <div id="chart-swap-usage" class="position-relative rounded-bottom chart-sm"></div>
    </div>
  </div>
</div>
<div class="col-sm-6 col-lg-3">
  <div class="card h-100">
    <div class="card-body d-flex flex-column">
      <div class="subheader">Disk</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.DiskTotal ?? 0)</div>
      <div class="subheader">Disk Used</div>
      <div class="h3">@GetGiB(RobotData?.SystemMonitoringInfo.DiskUsed ?? 0)</div>
      <div id="chart-disk-usage" class="position-relative rounded-bottom chart-sm"></div>
    </div>
  </div>
</div>

<script>
  var chartCpuUsageObj;
  function GenerateChartCpuUsage()
  {
    var options = {
      chart: {
        type: "radialBar",
        fontFamily: "inherit",
        height: 200,
        offsetY: -15,
        sparkline: {
          enabled: true,
        },
        animations: {
          enabled: false,
        },
      },
      plotOptions: {
        radialBar: {
          startAngle: -135,
          endAngle: 135,
          hollow: {
            margin: 16,
            size: "50%",
          },
          dataLabels: {
            show: true,
            value: {
              offsetY: -8,
              fontSize: "24px",
            },
          },
        },
      },
      labels: [""],
      tooltip: {
        theme: "dark",
      },
      grid: {
        strokeDashArray: 4,
      },
      legend: {
        show: false,
      }
    };
    chartCpuUsageObj = new ApexCharts(document.getElementById("chart-cpu-usage"), options);
    chartCpuUsageObj.render();
  }
  function UpdateChartCpuUsage(data)
  {
    chartCpuUsageObj.updateSeries([data])
  }
</script>
