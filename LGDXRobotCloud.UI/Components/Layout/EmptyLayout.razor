@using LGDXRobotCloud.UI.Services
@inherits LayoutComponentBase

<div class="page">
	<header class="navbar navbar-expand-lg navbar-light sticky-top d-none d-lg-flex">
		<div class="container header-flex">
			<h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal no-focus">
				<a href="">
					<img src="/img/logo@(IsDarkMode ? "-dark" : "").png" height="32" alt="LGDXRobot Cloud" class="navbar-brand-image">
				</a>
			</h1>
			<div class="navbar-nav flex-row order-md-last">
				<div class="nav-item d-none d-md-flex">
					<div class="btn-list">
						<SwitchRealmButton />
						<UserMenu />
					</div>
				</div>
			</div>
		</div>
	</header>
	<NavMenu />
	<div class="page-wrapper">
		@Body
	</div>
</div>

<LogoutModal />
<SwitchRealmModal />

<div id="blazor-error-ui">
	An unhandled error has occurred.
	<a href="" class="reload">Reload</a>
	<a class="dismiss">dismiss</a>
</div>

@code {
  [Inject]
	private ITokenService TokenService { get; set; } = default!;
	
	[Inject]
  public required AuthenticationStateProvider AuthenticationStateProvider { get; set; }
	
  public bool IsDarkMode { get; set; }

	protected override void OnInitialized()
	{
		var user = AuthenticationStateProvider.GetAuthenticationStateAsync().Result.User;
		var settings = TokenService.GetSessionSettings(user);
		IsDarkMode = settings.DarkMode;
	}
}